{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "sql:default",
    "sql:allow-execute",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://**" }]
    }
  ]
}